# Supabase 数据库连接（在 Supabase Dashboard → Settings → Database 获取）
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-[REGION].pooler.supabase.com:5432/postgres"

# Supabase 前端配置（在 Supabase Dashboard → Settings → API 获取）
VITE_SUPABASE_URL=https://[PROJECT_REF].supabase.co
VITE_SUPABASE_ANON_KEY=[YOUR_ANON_KEY]

# DeepSeek API Key（在 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY="sk-[YOUR_KEY]"

# 可选：MiniCPM-V / 云端托管视觉模型 API（OpenAI-compatible chat/completions）
# 未配置时，图片理解会自动降级为本地 OCR + 关键词标签。
MINICPM_V_API_URL="https://[YOUR_VLM_PROVIDER]/v1/chat/completions"
MINICPM_V_API_KEY="sk-[YOUR_KEY]"
MINICPM_V_MODEL="[YOUR_VLM_MODEL]"
